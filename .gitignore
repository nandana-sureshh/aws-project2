# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
**/dist/
backend/shared/dist/
backend/services/*/dist/

# Compiled JS output from TypeScript (should only be in dist/)
backend/shared/src/**/*.js
backend/shared/src/**/*.js.map
backend/shared/src/**/*.d.ts
backend/services/*/src/**/*.js
backend/services/*/src/**/*.js.map
backend/services/*/src/**/*.d.ts

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed

# Database
*.sqlite
*.sqlite3

# Docker
.dockerignore

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Uploads (local storage — not committed to git)
backend/uploads/

# TypeScript
*.tsbuildinfo



# Terraform
terraform/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/**/crash.log
terraform/providers/
# terraform.tfvars contains sensitive values — NEVER commit
