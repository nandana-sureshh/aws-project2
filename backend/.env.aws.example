# AWS Environment Variables Template
# Written by EC2 Launch Template user data to /opt/caresync/.env.aws
# This file does NOT contain secrets — secrets come from AWS Secrets Manager

# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# -------------------------------------------------------
# AWS Configuration
# These are injected by the Launch Template user data
# -------------------------------------------------------
AWS_REGION=us-east-1

# Secrets Manager — application fetches DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET
AWS_SECRETS_MANAGER_SECRET_NAME=caresync-dev-app-secrets

# S3 Storage
STORAGE_PROVIDER=s3
S3_BUCKET_NAME=caresync-dev-documents

# -------------------------------------------------------
# Provider Selection
# -------------------------------------------------------
NOTIFICATION_PROVIDER=database
EVENT_PROVIDER=console
QUEUE_PROVIDER=local

# -------------------------------------------------------
# JWT (values fetched from Secrets Manager at runtime)
# -------------------------------------------------------
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------------------
# CORS — update once you have a domain or CloudFront URL
# -------------------------------------------------------
CORS_ORIGIN=*

# -------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
MAX_FILE_SIZE_MB=10
