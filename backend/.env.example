# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://caresync_user:caresync_pass@localhost:5432/caresync_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=10
UPLOADS_DIR=./uploads

# Storage Provider (local | s3)
STORAGE_PROVIDER=local

# AWS S3 (for future S3StorageProvider)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=caresync-documents

# Notification Provider (database | sns)
NOTIFICATION_PROVIDER=database

# AWS SNS (for future SNSNotificationProvider)
# SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:caresync-notifications

# Event Provider (console | eventbridge)
EVENT_PROVIDER=console

# AWS EventBridge (for future EventBridgeProvider)
# EVENTBRIDGE_BUS_NAME=caresync-events

# Queue Provider (local | sqs)
QUEUE_PROVIDER=local

# AWS SQS (for future SQSQueueProvider)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/caresync-queue

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
